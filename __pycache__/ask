# -------------------------------------------------------------------------
# FastAPI wrapper for Voice Live quickstart
# -------------------------------------------------------------------------

import json
import os
import sys
import subprocess

import requests
from dotenv import load_dotenv
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

load_dotenv(os.path.join(os.path.dirname(os.path.abspath(__file__)), ".env"), override=True)

app = FastAPI(title="Voice Mode Agent API")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

BACKEND_DIR = os.path.dirname(os.path.abspath(__file__))
CONVERSATION_FILE = os.path.join(BACKEND_DIR, "logs", "last_conversation.json")

# Holds the running voice subprocess
_voice_process: subprocess.Popen | None = None


def _read_conversation() -> list[dict]:
    """Read the saved conversation history JSON."""
    if os.path.exists(CONVERSATION_FILE):
        try:
            with open(CONVERSATION_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            return []
    return []


def _generate_evaluation(conversation: list[dict]) -> dict:
    """Call Azure OpenAI chat completions to evaluate the sales conversation."""
    endpoint = os.getenv("AZURE_VOICELIVE_ENDPOINT", "").rstrip("/")
    api_key = os.getenv("AZURE_VOICELIVE_API_KEY", "")
    model = os.getenv("AZURE_VOICELIVE_MODEL", "gpt-4.1-mini")

    if not conversation:
        return {
            "strength": "No conversation recorded.",
            "weakness": "N/A",
            "rating": 0,
            "summary": "The session ended before any conversation took place.",
        }

    transcript = "\n".join(f"{m['role']}: {m['text']}" for m in conversation)

    url = f"{endpoint}/openai/deployments/{model}/chat/completions?api-version=2024-12-01-preview"
    headers = {"api-key": api_key, "Content-Type": "application/json"}
    body = {
        "messages": [
            {
                "role": "system",
                "content": (
                    "You are an expert sales trainer. Evaluate the salesperson based on "
                    "the conversation transcript below. Respond ONLY with valid JSON in "
                    "this exact format:\n"
                    '{"strength": "...", "weakness": "...", "rating": 7.5, "summary": "..."}\n'
                    "rating must be a number from 0 to 10."
                ),
            },
            {"role": "user", "content": transcript},
        ],
        "temperature": 0.7,
        "max_tokens": 500,
    }

    try:
        resp = requests.post(url, headers=headers, json=body, timeout=30)
        resp.raise_for_status()
        content = resp.json()["choices"][0]["message"]["content"]
        # Parse the JSON from the model response
        evaluation = json.loads(content)
        # Ensure expected keys exist
        return {
            "strength": evaluation.get("strength", ""),
            "weakness": evaluation.get("weakness", ""),
            "rating": float(evaluation.get("rating", 0)),
            "summary": evaluation.get("summary", ""),
        }
    except Exception as e:
        return {
            "strength": "Evaluation unavailable",
            "weakness": "Evaluation unavailable",
            "rating": 0,
            "summary": f"Could not generate evaluation: {e}",
        }


@app.post("/start-conversation")
async def start_conversation(body: dict = None):
    global _voice_process

    if _voice_process is not None and _voice_process.poll() is None:
        return {"status": "already_running", "message": "Voice session is already active."}

    # Clear old conversation file
    if os.path.exists(CONVERSATION_FILE):
        os.remove(CONVERSATION_FILE)

    env = os.environ.copy()
    if body and body.get("system_prompt"):
        env["EXTRA_SYSTEM_PROMPT"] = body["system_prompt"]

    _voice_process = subprocess.Popen(
        [sys.executable, "voice_live_quickstart.py"],
        cwd=BACKEND_DIR,
        env=env,
    )

    return {"status": "started", "message": "Voice session started."}


@app.post("/end-conversation")
async def end_conversation():
    global _voice_process

    # Stop the running voice process
    if _voice_process is not None and _voice_process.poll() is None:
        _voice_process.terminate()
        try:
            _voice_process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            _voice_process.kill()
    _voice_process = None

    # Read conversation history saved by the voice script
    conversation = _read_conversation()

    # Generate AI evaluation
    evaluation = _generate_evaluation(conversation)

    return {
        "status": "stopped",
        "transcript": conversation,
        **evaluation,
    }


@app.get("/status")
async def get_status():
    if _voice_process is not None and _voice_process.poll() is None:
        return {"status": "running"}
    return {"status": "idle"}
    return {"status": "idle"}
