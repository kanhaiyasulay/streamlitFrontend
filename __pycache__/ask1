def main():

    endpoint = os.environ.get("AZURE_VOICELIVE_ENDPOINT")
    api_key = os.environ.get("AZURE_VOICELIVE_API_KEY")
    model = os.environ.get("AZURE_VOICELIVE_MODEL", "gpt-realtime")
    voice = os.environ.get("AZURE_VOICELIVE_VOICE", "en-US-Ava:DragonHDLatestNeural")

    credential = AzureKeyCredential(api_key)

    base_instructions = """
You are pretending to be a potential customer evaluating a product.

Your personality:
- Curious
- Slightly skeptical
- Ask realistic questions
- Raise objections about price, ROI, competitors

Speak naturally like a human customer.
"""

    extra = os.environ.get("EXTRA_SYSTEM_PROMPT", "").strip()
    if extra:
        base_instructions += f"\n\nAdditional context:\n{extra}\n"

    assistant = BasicVoiceAssistant(
        endpoint,
        credential,
        model,
        voice,
        instructions=base_instructions
    )

    asyncio.run(assistant.start())

if __name__ == "__main__":

    p = pyaudio.PyAudio()

    input_devices = [
        i for i in range(p.get_device_count())
        if cast(int, p.get_device_info_by_index(i).get("maxInputChannels", 0)) > 0
    ]

    output_devices = [
        i for i in range(p.get_device_count())
        if cast(int, p.get_device_info_by_index(i).get("maxOutputChannels", 0)) > 0
    ]

    p.terminate()

    if not input_devices:
        print("No microphone detected.")
        sys.exit(1)

    if not output_devices:
        print("No speaker detected.")
        sys.exit(1)

    print("🎙️ Voice Mode Sales Trainer")
    print("=" * 40)

    main()
