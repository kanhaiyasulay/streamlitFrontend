# -------------------------------------------------------------------------
# AUDIO PROCESSOR
# -------------------------------------------------------------------------

class AudioProcessor:

    loop: asyncio.AbstractEventLoop

    class AudioPlaybackPacket:
        def __init__(self, seq_num: int, data: Optional[bytes]):
            self.seq_num = seq_num
            self.data = data

    def __init__(self, connection):

        self.connection = connection
        self.audio = pyaudio.PyAudio()

        self.format = pyaudio.paInt16
        self.channels = 1
        self.rate = 24000
        self.chunk_size = 1200

        self.input_stream = None

        self.playback_queue: queue.Queue[AudioProcessor.AudioPlaybackPacket] = queue.Queue()
        self.playback_base = 0
        self.next_seq_num = 0
        self.output_stream: Optional[pyaudio.Stream] = None

    def start_capture(self):

        def _capture_callback(in_data, _frame_count, _time_info, _status_flags):

            audio_base64 = base64.b64encode(in_data).decode("utf-8")

            asyncio.run_coroutine_threadsafe(
                self.connection.input_audio_buffer.append(audio=audio_base64),
                self.loop
            )

            return (None, pyaudio.paContinue)

        if self.input_stream:
            return

        self.loop = asyncio.get_event_loop()

        self.input_stream = self.audio.open(
            format=self.format,
            channels=self.channels,
            rate=self.rate,
            input=True,
            frames_per_buffer=self.chunk_size,
            stream_callback=_capture_callback,
        )

    def start_playback(self):

        if self.output_stream:
            return

        remaining = bytes()

        def _playback_callback(_in_data, frame_count, _time_info, _status_flags):

            nonlocal remaining
            frame_count *= pyaudio.get_sample_size(pyaudio.paInt16)

            out = remaining[:frame_count]
            remaining = remaining[frame_count:]

            while len(out) < frame_count:

                try:
                    packet = self.playback_queue.get_nowait()
                except queue.Empty:
                    out += bytes(frame_count - len(out))
                    continue

                if not packet or not packet.data:
                    break

                if packet.seq_num < self.playback_base:
                    remaining = bytes()
                    continue

                num_to_take = frame_count - len(out)
                out += packet.data[:num_to_take]
                remaining = packet.data[num_to_take:]

            return (out, pyaudio.paContinue)

        self.output_stream = self.audio.open(
            format=self.format,
            channels=self.channels,
            rate=self.rate,
            output=True,
            frames_per_buffer=self.chunk_size,
            stream_callback=_playback_callback
        )

    def queue_audio(self, audio_data: Optional[bytes]):

        self.playback_queue.put(
            AudioProcessor.AudioPlaybackPacket(
                seq_num=self.next_seq_num,
                data=audio_data
            )
        )

        self.next_seq_num += 1

    def skip_pending_audio(self):
        self.next_seq_num += 1

    def shutdown(self):

        if self.input_stream:
            self.input_stream.stop_stream()
            self.input_stream.close()

        if self.output_stream:
            self.output_stream.stop_stream()
            self.output_stream.close()

        if self.audio:
            self.audio.terminate()


# -------------------------------------------------------------------------
# VOICE ASSISTANT
# -------------------------------------------------------------------------

class BasicVoiceAssistant:

    def __init__(self, endpoint, credential, model, voice, instructions):

        self.endpoint = endpoint
        self.credential = credential
        self.model = model
        self.voice = voice
        self.instructions = instructions

        self.connection: Optional["VoiceLiveConnection"] = None
        self.audio_processor: Optional[AudioProcessor] = None

        self.conversation_history = []

        self.stop_requested = False

    async def start(self):

        async with connect(
            endpoint=self.endpoint,
            credential=self.credential,
            model=self.model,
        ) as connection:

            self.connection = connection

            ap = AudioProcessor(connection)
            self.audio_processor = ap

            await self._setup_session()

            ap.start_playback()

            print("\n🎤 SALES TRAINING SIMULATOR READY")
            print("Speak like a salesperson.")

            await self._process_events()

    async def _setup_session(self):

        voice_config = AzureStandardVoice(name=self.voice)

        turn_detection_config = ServerVad(
            threshold=0.5,
            prefix_padding_ms=300,
            silence_duration_ms=2000
        )

        session_config = RequestSession(

            modalities=[Modality.TEXT, Modality.AUDIO],

            instructions="""
You are pretending to be a potential customer evaluating a product.

Your personality:
- Curious
- Slightly skeptical
- Ask realistic questions
- Raise objections about price, ROI, competitors

Speak naturally like a human customer.
""",

            voice=voice_config,

            input_audio_format=InputAudioFormat.PCM16,
            output_audio_format=OutputAudioFormat.PCM16,

            turn_detection=turn_detection_config,

            input_audio_echo_cancellation=AudioEchoCancellation(),
            input_audio_noise_reduction=AudioNoiseReduction(type="azure_deep_noise_suppression"),
        )

        await self.connection.session.update(session=session_config)

    async def _process_events(self):

        async for event in self.connection:

            if self.stop_requested:
                break

            await self._handle_event(event)

    async def _handle_event(self, event):

        ap = self.audio_processor

        if event.type == ServerEventType.SESSION_UPDATED:
            ap.start_capture()

        elif event.type == ServerEventType.INPUT_AUDIO_BUFFER_SPEECH_STARTED:
            print("🎤 Listening...")
            ap.skip_pending_audio()

        elif event.type == ServerEventType.INPUT_AUDIO_BUFFER_SPEECH_STOPPED:
            print("🤔 Processing...")

        elif event.type == ServerEventType.RESPONSE_AUDIO_DELTA:
            ap.queue_audio(event.delta)

        elif event.type == ServerEventType.CONVERSATION_ITEM_CREATED:

            text = ""
            role = event.item.role

            if hasattr(event.item, "content") and event.item.content:
                for part in event.item.content:
                    if hasattr(part, "text"):
                        text += part.text

            if text:

                print(f"{role.upper()}: {text}")

                self.conversation_history.append({
                    "role": role,
                    "text": text
                })

                # Optional voice command exit
                if role == "user" and "exit" in text.lower():
                    await self.stop_and_generate_report()

    # ---------------------------------------------------------------------

    async def stop_and_generate_report(self):

        print("\nStopping conversation and generating report...\n")

        self.stop_requested = True

        await self.generate_evaluation()

    # ---------------------------------------------------------------------

    async def generate_evaluation(self):

        if not self.conversation_history:
            print("No conversation found.")
            return

        transcript = "\n".join(
            [f"{c['role']}: {c['text']}" for c in self.conversation_history]
        )

        evaluation_prompt = f"""
You are an expert sales trainer.

Evaluate the salesperson based on this conversation.

Conversation:
{transcript}

Provide the evaluation in this format:

Strengths:
- ...

Weaknesses:
- ...

Overall Rating:
X/10
"""

        await self.connection.response.create(
            response={
                "modalities": ["text"],
                "instructions": evaluation_prompt
            }
        )


