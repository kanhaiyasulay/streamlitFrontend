import streamlit as st
import asyncio
import os
from dotenv import load_dotenv
from azure.core.credentials import AzureKeyCredential

from voice_live_quickstart import BasicVoiceAssistant

load_dotenv()

st.set_page_config(
    page_title="AI Sales Training Simulator",
    page_icon="🎤",
    layout="wide"
)

st.title("🎤 AI Sales Training Simulator")
st.write("Practice your sales pitch with an AI customer.")

# Sidebar settings
st.sidebar.header("Settings")

voice = st.sidebar.selectbox(
    "AI Voice",
    [
        "en-US-Ava:DragonHDLatestNeural",
        "en-US-Guy:DragonHDLatestNeural"
    ]
)

scenario = st.sidebar.selectbox(
    "Customer Personality",
    [
        "Curious Customer",
        "Price Sensitive Customer",
        "Skeptical Customer"
    ]
)

# Initialize session state
if "conversation" not in st.session_state:
    st.session_state.conversation = []

if "running" not in st.session_state:
    st.session_state.running = False

col1, col2 = st.columns(2)

with col1:
    start_btn = st.button("▶ Start Conversation")

with col2:
    stop_btn = st.button("⏹ Stop & Evaluate")

endpoint = os.environ.get("AZURE_VOICELIVE_ENDPOINT")
api_key = os.environ.get("AZURE_VOICELIVE_API_KEY")
model = os.environ.get("AZURE_VOICELIVE_MODEL", "gpt-realtime")

credential = AzureKeyCredential(api_key)

async def run_agent():
    assistant = BasicVoiceAssistant(
        endpoint,
        credential,
        model,
        voice,
        instructions=""
    )

    await assistant.start()

if start_btn:

    st.session_state.running = True

    st.success("Voice session started. Speak into your microphone.")

    asyncio.run(run_agent())

if stop_btn:

    st.warning("Generating evaluation...")

# Conversation display

st.header("💬 Conversation")

chat_container = st.container()

with chat_container:

    if st.session_state.conversation:

        for msg in st.session_state.conversation:

            if msg["role"] == "user":
                st.chat_message("user").write(msg["text"])
            else:
                st.chat_message("assistant").write(msg["text"])

    else:
        st.info("Conversation will appear here once the session starts.")

# Evaluation area

st.header("📊 Performance Evaluation")

evaluation_placeholder = st.empty()

if not st.session_state.running:
    evaluation_placeholder.info(
        "Evaluation will appear after the conversation ends."
    )
